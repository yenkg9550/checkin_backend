# ── 資料庫 ──────────────────────────────────────────────────
# 本機一律用 docker compose 啟動，DATABASE_URL 會被 docker-compose.yml 自動覆蓋成 PostgreSQL，這裡不需要填。

# Render / 雲端 PostgreSQL（貼上 Render 提供的 Internal Database URL）
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ── JWT ─────────────────────────────────────────────────────
jwt_secret=請替換成隨機字串

# ── LINE ────────────────────────────────────────────────────
line_channel_id=
liff_id=
line_channel_secret=
line_channel_access_token=

# ── 超級管理員初始帳密 ────────────────────────────────────────
super_admin_username=superadmin
super_admin_password=
