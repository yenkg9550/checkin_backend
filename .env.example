# ── 資料庫 ──────────────────────────────────────────────────
# 本地 SQLite（預設，不需設定）
# database_url=sqlite+aiosqlite:///./checkin.db

# 本地 PostgreSQL
# DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/checkin

# Render / 雲端 PostgreSQL（貼上 Render 提供的 Internal Database URL）
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

